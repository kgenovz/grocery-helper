# Copy to .env and fill in. Compose reads this automatically.

# --- Postgres ---
POSTGRES_USER=grocery
POSTGRES_PASSWORD=grocery
POSTGRES_DB=grocery

# --- Caddy site address ---
# ":80" serves plain HTTP for local dev (http://localhost).
# For prod on Contabo, set a hostname to get automatic HTTPS, e.g.:
#   SITE_ADDRESS=grocery.yourdomain.com
SITE_ADDRESS=:80

# --- Minimal household auth (plan: one shared bearer token per household) ---
HOUSEHOLD_TOKEN=changeme

# --- Anthropic (Haiku) — ingredient parse + aisle classify (Phase 4+) ---
ANTHROPIC_API_KEY=

# --- PC Express pricing (Phase 7) — fill when implementing ---
# PCX_SUBSCRIPTION_KEY=
# PCX_STORE_ID=
